#!/bin/sh

npm_xdg() { # Hacer que npm use la especificación de directorios XDG
	[ -z "$NPM_CONFIG_USERCONFIG" ] && return

	_config_dir="$(dirname "$NPM_CONFIG_USERCONFIG")"
	mkdir -p "$_config_dir"
	cat <<-'EOF' | tee "$NPM_CONFIG_USERCONFIG"
		prefix=${XDG_DATA_HOME}/npm
		cache=${XDG_CACHE_HOME}/npm
		init-module=${XDG_CONFIG_HOME}/npm/config/npm-init.js
		tmp=${XDG_RUNTIME_DIR}/npm
		logfile=${XDG_CACHE_HOME}/npm/logs/npm.log
	EOF

	mv "$HOME/.npm/_cacache" "$XDG_CACHE_HOME/npm" 2>/dev/null
	mv "$HOME/.npm/_logs" "$XDG_CACHE_HOME/npm/logs" 2>/dev/null
	rm -rf "$HOME/.npm"
}

merge_delete() {
	_og="$1"
	_xdg="$2"
	if [ -d "$_og" ]; then
		cp -r "$_og" "$_xdg"
		rm -rf "$_og"
	fi
}

moveto_xdg() {
	_og="$1"
	_xdg="$2"
	if [ -f "$_og" ]; then
		mkdir "$(dirname "$_xdg")"
		mv -f "$_og" "$_xdg"
	fi
}

move_hardcoded_dir() {
	_og="$1"
	_xdg="$2"
	if [ ! -L "$_og" ] && [ -d "$OG" ]; then
		merge_delete "$_og" "$_xdg"
		ln -s "$_xdg" "$_og"
	fi
}

remove_if_only_contains() {
	_dir="$1"
	_keep="$2"

	[ -z "$(find "$_dir" -mindepth 1 -maxdepth 1 ! -name "$_keep" 2>/dev/null)" ] &&
		rm -rf "$_dir"
}

# Mover archivos según la especificación XDG
[ -d "$HOME/.npm" ] && npm_xdg

(
	merge_delete "$HOME/.pki" "$XDG_DATA_HOME/pki/"
	merge_delete "$HOME/.gnupg" "$XDG_DATA_HOME/gnupg"
	merge_delete "$HOME/.cargo" "$XDG_DATA_HOME/cargo"
	merge_delete "$HOME/go" "$XDG_DATA_HOME/go"
	merge_delete "$HOME/.sqlite_history" "$XDG_CACHE_HOME/sqlite_history"
	merge_delete "$HOME/.sonarlint" "$XDG_DATA_HOME/sonarlint"
	merge_delete "$HOME/.ipython" "$XDG_CONFIG_HOME/ipython"
	merge_delete "$HOME/.gradle" "$XDG_DATA_HOME/gradle"
	merge_delete "$HOME/.android" "$XDG_DATA_HOME/android"
	merge_delete "$HOME/.java" "$XDG_CONFIG_HOME"/java
	merge_delete "$HOME/.eclipse" "$XDG_CONFIG_HOME"/eclipse

	moveto_xdg "$HOME/.pulse-cookie" "$XDG_CONFIG_HOME/pulse/cookie"
	moveto_xdg "$HOME/.gitconfig" "$XDG_CONFIG_HOME/git/config"

	move_hardcoded_dir "$HOME/.java" "$XDG_CONFIG_HOME/java"
	move_hardcoded_dir "$HOME/.codetogether" "$HOME/.config/codetogether"
	move_hardcoded_dir "$HOME/.webclipse" "$HOME/.config/webclipse"
	move_hardcoded_dir "$HOME/wekafiles" "$XDG_DATA_HOME/weka"

	merge_delete "$HOME/.nix-channels" "$XDG_STATE_HOME/nix/channels"
	merge_delete "$HOME/.nix-defexpr" "$XDG_STATE_HOME/nix/defexpr"

	remove_if_only_contains "$HOME/.eclipse" "org.eclipse.oomph.p2"
	remove_if_only_contains "$HOME/.ssl" "obsidian-local-rest-api.crt"
) 2>/dev/null

# Borrar archivos
rm -f "$HOME/.wget-hsts"
rm -rf \
	"$HOME/.debug" \
	"$HOME/.fltk" \
	"$HOME/.gervill" \
	"$HOME/.gtkrc-2.0" \
	"$HOME/.junie" \
	"$HOME/.mono" \
	"$HOME/.nix-profile" \
	"$HOME/.tor project" \
	"$HOME/.wget-hsts" \
	"$HOME/.wine" \
	"$HOME/.xsession-errors" \
	"$HOME/.yarnrc" \
	"$HOME/.zynaddsubfx-bank-cache.xml" \
	"$HOME/Escritorio" \
	"$HOME/steam.desktop" \
	"$XDG_CONFIG_HOME/menus" \
	"$XDG_DATA_HOME/applications/wine"* \
	"$XDG_DATA_HOME/desktop-directories" \
	"$HOME/.python_history" \
	2>/dev/null

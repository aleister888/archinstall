#!/bin/bash
# shellcheck disable=SC2068

source "$HOME/.dotfiles/assets/shell/shell-utils"

CONFIG="$HOME/.config/hypr/hyprland/appearance.conf"
STATE_FILE="/tmp/hypr-decorations-state"

GAPS_IN="$(grep -oP "gaps_in = \K.*" "$CONFIG")"
GAPS_OUT="$(grep -oP "gaps_out = \K.*" "$CONFIG")"
BORDER_SIZE="$(grep -oP "border_size = \K.*" "$CONFIG")"

for var in "$GAPS_IN" "$GAPS_OUT" "$BORDER_SIZE"; do
	if ! [[ "$var" =~ ^[0-9]+$ ]]; then
		log "error al leer $CONFIG"
		exit 1
	fi
done

# Leer el estado actual
if [ -f "$STATE_FILE" ] && [ "$(cat $STATE_FILE)" = "off" ]; then
	# Activar bordes y gaps
	hyprctl keyword general:gaps_in "$GAPS_IN"
	hyprctl keyword general:gaps_out "$GAPS_OUT"
	hyprctl keyword general:border_size "$BORDER_SIZE"
	echo "on" >"$STATE_FILE"
	notify-send "Hyprland" "Bordes y gaps activados" --expire-time=1500
else
	# Desactivar bordes y gaps
	hyprctl keyword general:gaps_in 0
	hyprctl keyword general:gaps_out 0
	hyprctl keyword general:border_size 0
	echo "off" >"$STATE_FILE"
	notify-send "Hyprland" "Bordes y gaps desactivados" --expire-time=1500
fi

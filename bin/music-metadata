#!/bin/bash
# shellcheck disable=SC1091

. "$HOME/.dotfiles/assets/shell/shell-utils-sh"

TMP_DIR="$(get_cache_tmp_dir music-metadata)"

shopt -s extglob

# Número máximo de caracteres del output
[ -z "$FACT" ] && FACT=24
[ -z "$ALTFACT" ] && ALTFACT=12

# Establecemos el reproductor
PLAYER="$(music-priority)"
# Si la música se está reproduciendo en el navegador, esperamos un tiempo
[ "$PLAYER" = "$BROWSER" ] && sleep 1

is_image() {
	case "$(file --dereference --brief --mime-type "$1")" in
	image/*) return 0 ;;
	*) return 1 ;;
	esac
}

makesafe() {
	if [ "${#1}" -gt "$FACT" ]; then
		local CROPPED="${1:0:$((FACT - 3))}"
		echo "${CROPPED% }… "
	else
		[ -z "$1" ] || echo "$1"
	fi
}

statusbar() {
	[ -z "$PLAYER" ] && exit

	local TITLE STATUS INDICATOR

	# Obtener el título de la canción y estado de la reproducción
	TITLE=$(metaprint title)
	STATUS="$(playerctl status --player="$PLAYER")"

	[ -z "$TITLE" ] && exit

	if [ "$STATUS" == "Playing" ]; then
		#INDICATOR="Playing:"
		INDICATOR=""
	elif [ -n "$STATUS" ]; then
		#INDICATOR="Paused:"
		INDICATOR=""
	fi
	#INDICATOR="<b>$INDICATOR</b>"

	echo "$INDICATOR <i>$TITLE</i>"
}

metaprint() {
	local OUT

	if [ -z "$PLAYER" ]; then
		case "$1" in
		title) OUT="Reproductor cerrado" ;;
		album) OUT="No se pudo obtener la información" ;;
		artist) OUT="No se pudo obtener la información" ;;
		esac
	else
		case "$1" in
		title | album | artist)
			OUT="$(playerctl metadata --player="$PLAYER" "$1")"
			;;
		esac
	fi

	[ -z "$OUT" ] && return 1

	[ "$WITHSAFE" == "true" ] && OUT=$(makesafe "$OUT")

	echo "${OUT%%+([[:space:]])}"
}

# shellcheck disable=SC2155
get_cover() {
	local PLACEHOLDER="$HOME/.dotfiles/assets/images/music-control_placeholder.png"
	local COVER COVER_FILE MBID ARTIST ALBUM
	COVER=$(playerctl --player="$PLAYER" metadata mpris:artUrl)
	COVER_FILE="${TMP_DIR}/cover"
	rm -f "$COVER_FILE"

	if [[ $COVER =~ ^file:// ]]; then
		echo "${COVER#file://}"
		return
	fi

	# Si el archivo no está en local, lo descargamos usando el MBID para tener
	# una caché global que sirva para todos los servicios
	ARTIST="$(playerctl metadata --player="$PLAYER" artist)"
	ALBUM="$(playerctl metadata --player="$PLAYER" album)"
	if [ -n "$ARTIST" ] && [ -n "$ALBUM" ]; then
		MBID=$(curl -sG "https://musicbrainz.org/ws/2/release/" \
			--data-urlencode "query=artist:${ARTIST} release:${ALBUM}" \
			--data-urlencode "fmt=json" | jq -r '.releases[0].id // empty')
		if [ -n "$MBID" ]; then
			COVER_FILE="${TMP_DIR}/$MBID"
			if [ ! -s "$COVER_FILE" ]; then
				curl -sL \
					"https://coverartarchive.org/release/$MBID/front" \
					-o "$COVER_FILE"
				if [ -s "$COVER_FILE" ] && ! is_image "$COVER_FILE"; then
					rm -f "$COVER_FILE"
				fi
			fi
		fi
	fi

	# Si no se pudo descargar unsando el MBID usamos la URL de playerct
	if [ ! -s "$COVER_FILE" ] && [[ $COVER =~ ^https:// ]]; then
		COVER_FILE="${TMP_DIR}/cover"
		wget -q "$COVER" -O "$COVER_FILE"
	fi

	if [ -s "$COVER_FILE" ]; then
		echo "$COVER_FILE"
	else
		echo "$PLACEHOLDER"
	fi
}

help_msg() {
	cat >&2 <<-EOF
		Uso:
		  $(basename "$0") [-Sdtacsh]

		OPCIONES:
		  -S Habilitar máximo de caracteres ($FACT para -d, $ALTFACT para -t/-a/-A)
		  -d Imprimir información para la barra de estado (-S activado)
		  -t Imprime el titulo
		  -a Imprime el artista
		  -A Imprime el álbum
		  -c Imprime la localización en cache de la caratula o un placeholder si no encuentra ninguno
		  -s Imprime el estado de la reproducción
		  -h Muestra este mensaje

		NOTA:
		  Puedes cambiar el máximo de caracteres para -d con la variable \$FACT y el máximo para -t/-a con la variable \$ALTFACT"
	EOF
}

if grep -q "\-h\|--help" <<<"$@"; then
	help_msg
	exit
fi

while [[ "$#" -gt 0 ]]; do
	case "$1" in
	-S)
		WITHSAFE=true
		;;
	-d)
		WITHSAFE=true
		statusbar
		exit
		;;
	-t)
		FACT=$ALTFACT
		metaprint title
		exit
		;;
	-a)
		FACT=$ALTFACT
		metaprint artist
		exit
		;;
	-A)
		FACT=$ALTFACT
		metaprint album
		exit
		;;
	-c)
		get_cover
		exit
		;;
	-s)
		[ -n "$PLAYER" ] && playerctl status --player="$PLAYER"
		exit
		;;
	*)
		help_msg
		exit
		;;
	esac
	shift
done

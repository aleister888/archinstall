#!/bin/bash
# shellcheck disable=SC2068

source "$HOME/.dotfiles/assets/shell/shell-utils"

is_process_running Xephyr || Xephyr -br -ac -resizeable -screen 1920x1080 :1 &
sleep 1

export DISPLAY=:1

is_process_running openbox || openbox &
sleep 1

is_process_running picom || picom &

pw-metadata -n settings 0 clock.force-rate 96000
pw-metadata -n settings 0 clock.force-quantum 192

exec env DISPLAY=:1 WAYLAND_DISPLAY= "$@"
